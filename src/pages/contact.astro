---
import Layout from "../layouts/Layout.astro";
import { profile } from "../data.js";

const title = `Contact | ${profile.name}`;
---

<Layout title={title} description={profile.metaDescription}>
  <main>
    <div class="contact-container">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="intro">
        Reach out for backend engineering, AI application, automation, or computer vision work.
      </p>

      <ul class="social-list">
        <li>
          <a href={`mailto:${profile.email}`}>
            <span class="icon">@</span>
            <span>Email <b>{profile.email}</b></span>
          </a>
        </li>
        <li>
          <a href={profile.github} target="_blank" rel="noopener noreferrer">
            <span class="icon">GH</span>
            <span>View my code on <b>GitHub</b></span>
          </a>
        </li>
        <li>
          <a href={profile.linkedin} target="_blank" rel="noopener noreferrer">
            <span class="icon">in</span>
            <span>Connect on <b>LinkedIn</b></span>
          </a>
        </li>
        <li>
          <a href={`https://${profile.website}`} target="_blank" rel="noopener noreferrer">
            <span class="icon">www</span>
            <span>Visit <b>{profile.website}</b></span>
          </a>
        </li>
      </ul>
    </div>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 70px);
    background: var(--color-primary);
    padding-top: 70px;
    width: 100%;
  }

  .contact-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-accent-cool);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
    background: linear-gradient(to right, var(--color-text), var(--color-accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .intro {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
    line-height: 1.6;
    text-align: center;
  }

  .social-list {
    list-style-type: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  li {
    transition: transform 0.3s ease;
  }

  li:hover {
    transform: translateY(-3px);
  }

  a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.035);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.3s ease;
  }

  a:hover,
  a:focus-visible {
    background: rgba(255, 255, 255, 0.07);
    outline: none;
  }

  .icon {
    width: 42px;
    height: 42px;
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 900;
  }

  span {
    color: var(--color-text-muted);
  }

  b {
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  a:hover b {
    color: var(--color-accent-cool);
  }

  @media (max-width: 768px) {
    .contact-container {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .intro {
      font-size: 1rem;
    }

    a {
      padding: 0.75rem;
    }
  }
</style>
