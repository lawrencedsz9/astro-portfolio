---
export interface Props {
  heading?: string;
  text?: string;
  showExtra?: boolean;
}

const { 
  heading = "Hi, I'm Lawrence", 
  text = "just a person who is interested to build and explore new things",
  showExtra = false 
} = Astro.props as Props;
---

<section class="showcase">
  <div class="container">
    <div class="showcase-content">
      <div class="showcase-text">
        <div class="text-content">
          <span class="greeting">Developer.</span>
          <h1 class="giant-heading">{heading}</h1>
          <p class="subtitle">{text}</p>

          <div class="tags-container">
            <span class="tag pill"><span class="dot js"></span> Web</span>
            <span class="tag pill"><span class="dot react"></span> Design</span>
            <span class="tag pill"><span class="dot astro"></span> Problem Solving</span>
          </div>

          <!-- right interactive LangGraph-like node animation -->
          <aside aria-hidden="true">
            <canvas id="hero-graph" width="600" height="600" role="img" aria-label="Network graph animation"></canvas>
          </aside>
          {showExtra && (
            <div class="showcase-cta">
              <a href="#projects" class="btn btn-primary">Projects</a>
              <a href="/contact" class="btn btn-outline">Contact</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  .showcase-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .greeting {
    font-family: monospace;
    color: var(--color-text-muted);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .giant-heading {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    margin: 0;
    color: var(--color-text);
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    backdrop-filter: blur(4px);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot.js { background: #f7df1e; }
  .dot.react { background: #61dafb; }
  .dot.astro { background: #ff5d01; }

  .showcase-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .showcase aside { margin-top: 18px; }
  #hero-graph { display:block; width: min(420px, 48vw); height: auto; border-radius:14px; background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02)); box-shadow: 0 6px 30px rgba(0,0,0,0.6); }

  @media (max-width: 768px) {
    .giant-heading {
      font-size: 3rem;
    }
  }
</style>

<script>
  // LangGraph-like node animation (canvas)
  (function(){
    const run = () => {
      const canvas = document.getElementById('hero-graph');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let DPR = window.devicePixelRatio || 1;

      function resize() {
        const rect = canvas.getBoundingClientRect();
        const s = Math.max(200, rect.width);
        canvas.width = Math.floor(s * DPR);
        canvas.height = Math.floor(s * DPR);
        canvas.style.height = (s) + 'px';
        ctx.setTransform(DPR,0,0,DPR,0,0);
      }

      function rand(min,max){return Math.random()*(max-min)+min}
      const NODE_COUNT = 28; const nodes = [];
      function init(){ nodes.length=0; const size = canvas.getBoundingClientRect().width; for(let i=0;i<NODE_COUNT;i++){ nodes.push({ x:rand(size*0.12,size*0.88), y:rand(size*0.12,size*0.88), vx:rand(-0.25,0.25), vy:rand(-0.25,0.25), r:rand(2.5,6), active:0 }); } }

      function draw(){ const size = canvas.width/DPR; ctx.clearRect(0,0,size,size); const maxDist = size*0.28; for(let i=0;i<nodes.length;i++){ for(let j=i+1;j<nodes.length;j++){ const a=nodes[i], b=nodes[j]; const dx=a.x-b.x, dy=a.y-b.y, d=Math.hypot(dx,dy); if(d<maxDist){ const alpha=1-d/maxDist; ctx.strokeStyle = `rgba(160,160,180,${0.08*alpha+0.02})`; ctx.lineWidth = 1*alpha; ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke(); } } } nodes.forEach(n=>{ ctx.beginPath(); const glow=8*(n.active||0.2); const g=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r+glow); g.addColorStop(0,`rgba(255,255,255,${0.9*(n.active||0.6)})`); g.addColorStop(0.6,`rgba(200,200,220,${0.25*(n.active||0.6)})`); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.arc(n.x,n.y,n.r+(n.active?2:0),0,Math.PI*2); ctx.fill(); }); }

      let last = performance.now(), raf = null;
      function tick(t){ const dt = Math.min(40,t-last)/16.666; last = t; const size = canvas.width/DPR; for(const n of nodes){ n.x += n.vx*dt*12; n.y += n.vy*dt*12; if(n.x < size*0.08 || n.x > size*0.92) n.vx *= -1; if(n.y < size*0.08 || n.y > size*0.92) n.vy *= -1; n.vx += rand(-0.02,0.02)*dt; n.vy += rand(-0.02,0.02)*dt; n.active = Math.max(0,(n.active||0)-0.01*dt); } draw(); raf = requestAnimationFrame(tick); }

      function onPointer(e){ const rect = canvas.getBoundingClientRect(); const x = e.clientX - rect.left; const y = e.clientY - rect.top; let nearest=null, nd=9999; for(const n of nodes){ const d=Math.hypot(n.x-x,n.y-y); if(d<nd){ nd=d; nearest=n; } } if(nearest && nd<80){ nearest.active = 1.2; for(const k of nodes){ const d2=Math.hypot(k.x-nearest.x,k.y-nearest.y); if(d2<140){ k.vx += (k.x-nearest.x)*0.0008; k.vy += (k.y-nearest.y)*0.0008; } } } }

      function start(){ DPR = window.devicePixelRatio||1; resize(); init(); if(raf) cancelAnimationFrame(raf); last = performance.now(); raf = requestAnimationFrame(tick); }
      window.addEventListener('resize',()=>{ DPR = window.devicePixelRatio||1; resize(); });
      canvas.addEventListener('pointermove', onPointer); canvas.addEventListener('pointerdown', onPointer);
      start();
    };
    if (document.readyState === 'complete' || document.readyState === 'interactive') run(); else document.addEventListener('DOMContentLoaded', run);
  })();
</script>
