---
export interface Props {
  heading?: string;
  text?: string;
  showExtra?: boolean;
}

const { 
  heading = "Hi, I'm Lawrence", 
  text = "I build backend systems, AI applications, and real-time software for web, mobile, and edge devices.",
  showExtra = false 
} = Astro.props as Props;
---

<section class="showcase">
  <div class="container">
    <div class="showcase-content">
      <div class="showcase-text">
        <div class="text-content">
          <span class="greeting">Developer.</span>
          <h1 class="giant-heading">{heading}</h1>
          <p class="subtitle">{text}</p>

          <div class="tags-container">
            <span class="tag pill"><span class="dot js"></span> Web</span>
            <span class="tag pill"><span class="dot react"></span> Design</span>
            <span class="tag pill"><span class="dot astro"></span> Problem Solving</span>
          </div>

          <!-- right interactive LangGraph-like node animation -->
          <aside aria-hidden="true">
            <canvas id="hero-graph" width="600" height="600" role="img" aria-label="Network graph animation"></canvas>
          </aside>
          {showExtra && (
            <div class="showcase-cta">
              <a href="#projects" class="btn btn-primary">Projects</a>
              <a href="/contact" class="btn btn-outline">Contact</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  .showcase-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .greeting {
    font-family: monospace;
    color: var(--color-text-muted);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .giant-heading {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    margin: 0;
    color: var(--color-text);
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    backdrop-filter: blur(4px);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot.js { background: #f7df1e; }
  .dot.react { background: #61dafb; }
  .dot.astro { background: #ff5d01; }

  .showcase-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .showcase aside { margin-top: 18px; }
  #hero-graph { display:block; width: min(420px, 48vw); height: auto; border-radius:14px; background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02)); box-shadow: 0 6px 30px rgba(0,0,0,0.6); }

  @media (max-width: 768px) {
    .giant-heading {
      font-size: 3rem;
    }
  }
</style>

<script>
  (() => {
    const run = () => {
      const target = document.getElementById('hero-graph');
      if (!(target instanceof HTMLCanvasElement)) return;

      const canvas = target;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let dpr = window.devicePixelRatio || 1;
      let last = performance.now();
      let raf = 0;
      const nodeCount = 28;
      const createNode = () => ({
        x: 0,
        y: 0,
        vx: 0,
        vy: 0,
        r: 0,
        active: 0,
      });
      const nodes = Array.from({ length: nodeCount }, createNode);

      const rand = (min = 0, max = 1) => Math.random() * (max - min) + min;

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        const size = Math.max(200, rect.width);
        canvas.width = Math.floor(size * dpr);
        canvas.height = Math.floor(size * dpr);
        canvas.style.height = `${size}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const init = () => {
        const size = canvas.getBoundingClientRect().width;

        nodes.forEach((node) => {
          node.x = rand(size * 0.12, size * 0.88);
          node.y = rand(size * 0.12, size * 0.88);
          node.vx = rand(-0.25, 0.25);
          node.vy = rand(-0.25, 0.25);
          node.r = rand(2.5, 6);
          node.active = 0;
        });
      };

      const draw = () => {
        const size = canvas.width / dpr;
        const maxDist = size * 0.28;
        ctx.clearRect(0, 0, size, size);

        for (let i = 0; i < nodes.length; i += 1) {
          for (let j = i + 1; j < nodes.length; j += 1) {
            const a = nodes[i];
            const b = nodes[j];
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const distance = Math.hypot(dx, dy);

            if (distance < maxDist) {
              const alpha = 1 - distance / maxDist;
              ctx.strokeStyle = `rgba(160,160,180,${0.08 * alpha + 0.02})`;
              ctx.lineWidth = alpha;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }

        nodes.forEach((node) => {
          const glow = 8 * (node.active || 0.2);
          const gradient = ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, node.r + glow);

          gradient.addColorStop(0, `rgba(255,255,255,${0.9 * (node.active || 0.6)})`);
          gradient.addColorStop(0.6, `rgba(200,200,220,${0.25 * (node.active || 0.6)})`);
          gradient.addColorStop(1, 'rgba(0,0,0,0)');

          ctx.beginPath();
          ctx.fillStyle = gradient;
          ctx.arc(node.x, node.y, node.r + (node.active ? 2 : 0), 0, Math.PI * 2);
          ctx.fill();
        });
      };

      const tick = (time = performance.now()) => {
        const delta = Math.min(40, time - last) / 16.666;
        const size = canvas.width / dpr;
        last = time;

        nodes.forEach((node) => {
          node.x += node.vx * delta * 12;
          node.y += node.vy * delta * 12;

          if (node.x < size * 0.08 || node.x > size * 0.92) node.vx *= -1;
          if (node.y < size * 0.08 || node.y > size * 0.92) node.vy *= -1;

          node.vx += rand(-0.02, 0.02) * delta;
          node.vy += rand(-0.02, 0.02) * delta;
          node.active = Math.max(0, (node.active || 0) - 0.01 * delta);
        });

        draw();
        raf = requestAnimationFrame(tick);
      };

      const onPointer = (event = new PointerEvent('pointermove')) => {
        const rect = canvas.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        let nearestIndex = -1;
        let nearestDistance = Number.POSITIVE_INFINITY;

        nodes.forEach((node, index) => {
          const distance = Math.hypot(node.x - x, node.y - y);
          if (distance < nearestDistance) {
            nearestDistance = distance;
            nearestIndex = index;
          }
        });

        if (nearestIndex < 0 || nearestDistance >= 80) return;

        const nearest = nodes[nearestIndex];
        if (!nearest) return;

        nearest.active = 1.2;
        const nearestX = nearest.x;
        const nearestY = nearest.y;

        nodes.forEach((node) => {
          const distance = Math.hypot(node.x - nearestX, node.y - nearestY);
          if (distance < 140) {
            node.vx += (node.x - nearestX) * 0.0008;
            node.vy += (node.y - nearestY) * 0.0008;
          }
        });
      };

      const start = () => {
        dpr = window.devicePixelRatio || 1;
        resize();
        init();
        if (raf) cancelAnimationFrame(raf);
        last = performance.now();
        raf = requestAnimationFrame(tick);
      };

      window.addEventListener('resize', () => {
        dpr = window.devicePixelRatio || 1;
        resize();
      });
      canvas.addEventListener('pointermove', onPointer);
      canvas.addEventListener('pointerdown', onPointer);
      start();
    };

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      run();
    } else {
      document.addEventListener('DOMContentLoaded', run);
    }
  })();
</script>



