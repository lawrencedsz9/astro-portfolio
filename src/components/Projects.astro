---
import { projects } from '../data.js';
import Card from './Card.astro';

// Chunk projects into arrays of 4 (2x2 grid pages)
const chunkSize = 4;
const projectChunks = [];
for (let i = 0; i < projects.length; i += chunkSize) {
  projectChunks.push(projects.slice(i, i + chunkSize));
}
---

<section class="projects-section" id="projects">
  <div class="projects-container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Projects</h2>
      </div>
    </div>

    <!-- Carousel Container -->
    <div class="carousel-container">
      <div class="carousel-track">
        {projectChunks.map((chunk, pageIndex) => (
          <div class="carousel-page">
            {chunk.map((project, index) => {
              const isFeatured = pageIndex === 0 && index < 2;
              return (
                <Card dark={true} class={isFeatured ? "featured-card" : "project-card"}>
                  {isFeatured && index === 1 && <div class="icon-badge" aria-hidden="true">+</div>}
                  <p class="card-label">{isFeatured ? 'FEATURED' : 'PROJECT'}</p>
                  <h3 class="card-title">{project.name}</h3>
                  <p class="card-description">{project.description}</p>
                  
                  <div class="tech-stack">
                    {project.stack.map((tech) => (
                      <span class="tech-badge">{tech}</span>
                    ))}
                  </div>

                  <a href={project.link} target="_blank" rel="noopener noreferrer" class="view-link">
                    {isFeatured ? 'See how it works ->' : 'View Project ->'}
                  </a>
                </Card>
              );
            })}
          </div>
        ))}
      </div>

      <!-- Carousel Dots -->
      <div class="carousel-dots" aria-hidden="true">
        {projectChunks.map((_, i) => (
          <span class={`dot ${i === 0 ? 'active' : ''}`} data-slide={i}></span>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Carousel functionality
  const track = document.querySelector('.carousel-track');
  const dots = document.querySelectorAll('.carousel-dots .dot');

  if (track && dots.length > 0) {
    // Update dots on scroll (touchpad swipe natively triggers this)
    track.addEventListener('scroll', () => {
      const scrollRatio = track.scrollLeft / track.clientWidth;
      const currentSlide = Math.round(scrollRatio);

      dots.forEach((dot, index) => {
        if (index === currentSlide) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    });

    // Make dots clickable
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        track.scrollTo({
          left: index * track.clientWidth,
          behavior: 'smooth'
        });
      });
    });
  }
</script>

<style>
  .projects-section {
    width: 100%;
    padding: 5rem 0;
    background: var(--color-primary);
  }

  .projects-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1.5rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .section-header h2 {
    margin: 0;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .year-range {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-style: italic;
  }

  /* Carousel */
  .carousel-container {
    width: 100%;
  }

  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  .carousel-track::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .carousel-page {
    min-width: 100%;
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1.5rem;
  }

  .featured-card,
  .project-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: 360px;
  }

  .icon-badge {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--color-text-muted);
    font-weight: 700;
    line-height: 1;
  }

  .card-label {
    margin: 0 0 1rem;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .card-title {
    margin: 0 0 1.25rem;
    color: var(--color-text);
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.12;
  }

  .card-description {
    margin: 0 0 1.5rem;
    color: var(--color-accent-light);
    font-size: 1rem;
    line-height: 1.7;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .tech-badge {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .view-link {
    display: inline-flex;
    width: fit-content;
    margin-top: 1.25rem;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 700;
  }

  /* Carousel Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 2.5rem;
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: var(--color-text);
    width: 1.8rem;
    border-radius: 999px;
  }

  .dot:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 4rem 0;
    }

    .projects-container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
    }

    .section-header h2 {
      font-size: 2rem;
      text-align: left;
    }

    .carousel-track {
      display: block;
      overflow: visible;
      scroll-snap-type: none;
    }

    .carousel-page {
      min-width: 0;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: none;
      gap: 1rem;
    }

    .carousel-page + .carousel-page {
      margin-top: 1rem;
    }

    .featured-card,
    .project-card {
      min-height: auto;
      padding: 1.25rem;
    }

    .card-title {
      font-size: 1.65rem;
    }

    .card-description {
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .carousel-dots {
      display: none;
    }
  }

  @media (max-width: 420px) {
    .projects-container {
      padding: 0 0.875rem;
    }

    .featured-card,
    .project-card {
      padding: 1rem;
    }

    .card-title {
      font-size: 1.45rem;
    }

    .card-description {
      font-size: 0.94rem;
    }
  }
</style>

