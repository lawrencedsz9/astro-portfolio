---
import { profile } from '../data.js';

export interface Props {
  heading?: string;
  text?: string;
  tags?: string[];
  showExtra?: boolean;
}

const {
  heading = profile.hero.heading,
  text = profile.hero.text,
  tags = profile.hero.tags,
  showExtra = false
} = Astro.props as Props;
---

<section class="spline-landing" id="home">
  <div class="container landing-container">
    <div class="landing-content">
      <span class="greeting">{profile.role}</span>
      <h1 class="giant-heading">{heading}</h1>
      <p class="subtitle">{text}</p>

      <div class="tags-container" aria-label="Core skills">
        {tags.map((tag, index) => (
          <span class="tag"><span class={`dot tone-${index % 4}`}></span> {tag}</span>
        ))}
      </div>

      {showExtra && (
        <div class="landing-cta">
          <a href="#projects" class="btn btn-primary">Projects</a>
          <a href="#contact" class="btn btn-outline">Contact</a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .spline-landing {
    min-height: 100svh;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
    padding: clamp(7rem, 12vh, 9rem) 0 clamp(4rem, 9vh, 6rem);
    pointer-events: none;
  }

  .landing-container {
    position: relative;
    z-index: 2;
  }

  .landing-content {
    width: min(690px, 100%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.35rem;
    pointer-events: auto;
  }

  .landing-content * {
    pointer-events: auto;
  }

  .greeting {
    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
    color: var(--color-accent-cool);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
  }

  .giant-heading {
    font-size: clamp(3.25rem, 8vw, 6.75rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: 0;
    margin: 0;
    color: var(--color-text);
    max-width: 9ch;
  }

  .subtitle {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0;
    font-weight: 300;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.35rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.4rem;
    padding: 0.55rem 0.9rem;
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(226, 232, 240, 0.12);
    border-radius: 999px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    backdrop-filter: blur(12px);
  }

  .dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    flex: 0 0 auto;
  }

  .tone-0 { background: var(--color-accent-cool); }
  .tone-1 { background: var(--color-accent-mint); }
  .tone-2 { background: var(--color-accent-warm); }
  .tone-3 { background: var(--color-accent-light); }

  .landing-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .spline-landing {
      min-height: 105svh;
      align-items: flex-end;
      padding: 7.75rem 0 4rem;
    }

    .landing-content {
      width: 100%;
      padding-top: 44vh;
    }

    .giant-heading {
      max-width: 10ch;
      font-size: clamp(3rem, 13vw, 4.8rem);
    }
  }

  @media (max-width: 520px) {
    .spline-landing {
      padding-bottom: 3rem;
    }

    .landing-content {
      gap: 1.1rem;
      padding-top: 42vh;
    }

    .subtitle {
      font-size: 1rem;
      line-height: 1.65;
    }

    .tags-container {
      gap: 0.55rem;
    }

    .tag {
      min-height: 2.25rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.82rem;
    }
  }
</style>
