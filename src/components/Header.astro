---
import logo from '../images/user.jpg';
import { profile } from '../data.js';
---

<header class="header">
  <div class="container">
    <div class="logo">
      <a href="/#home" class="profile">
        <img src={logo.src} alt="Lawrence Dsouza" width="60" height="60" />
        <span class="name">{profile.displayName}</span>
      </a>
    </div>
    <nav class="nav" id="site-nav" aria-label="Main navigation">
      <ul>
        <li><a href="/#home">Home</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#projects">Projects</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </nav>
    <button class="mobile-menu-btn" aria-label="Toggle Menu" aria-controls="site-nav" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.querySelector('.mobile-menu-btn');
    const nav = document.querySelector('.nav');

    const setMenuOpen = (open: boolean) => {
      menuBtn?.classList.toggle('open', open);
      nav?.classList.toggle('open', open);
      document.body.classList.toggle('menu-open', open);

      if (menuBtn instanceof HTMLButtonElement) {
        menuBtn.setAttribute('aria-expanded', String(open));
      }
    };
    
    menuBtn?.addEventListener('click', () => {
      setMenuOpen(!menuBtn.classList.contains('open'));
    });

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        setMenuOpen(false);
      });
    });
  });
</script>

<style>
  .header {
    height: 60px;
    background: rgba(24, 24, 27, 0.6);
    backdrop-filter: blur(12px);
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    transition: all 0.3s ease;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
    width: auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
  }

  .header .container {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    gap: 1.5rem;
  }

  .profile {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .profile:hover {
    opacity: 0.9;
  }

  .name {
    font-size: 1rem;
    font-weight: 700;
    white-space: nowrap;
    color: #fff;
    display: block;
    text-transform: none;
  }

  .header img {
    height: 40px;
    width: 40px;
    border-radius: 50%;
    object-fit: cover;
    transition: all 0.3s ease;
  }

  .nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav ul li a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
    text-transform: lowercase;
  }

  .nav ul li a:hover,
  .nav ul li a:focus-visible {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    outline: none;
  }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
  }

  .bar {
    display: block;
    width: 25px;
    height: 3px;
    margin: 5px auto;
    background-color: white;
    transition: all 0.3s ease-in-out;
  }

  @media (max-width: 768px) {
    .header {
      top: 12px;
      width: calc(100% - 2rem);
      height: 58px;
      padding: 0 0.625rem 0 0.75rem;
    }

    .header .container {
      width: 100%;
      padding: 0;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .profile {
      gap: 0.5rem;
    }

    .name {
      max-width: 52vw;
      overflow: hidden;
      text-overflow: ellipsis;
      font-size: 0.95rem;
    }

    .mobile-menu-btn {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .mobile-menu-btn.open .bar:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .mobile-menu-btn.open .bar:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu-btn.open .bar:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    .nav {
      position: fixed;
      top: 74px;
      right: 1rem;
      width: calc(100vw - 2rem);
      max-width: 360px;
      height: auto;
      padding: 1rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: var(--color-primary);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
      box-shadow: var(--shadow-lg);
    }

    .nav.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav ul {
      flex-direction: column;
      width: 100%;
      align-items: center;
      gap: 0.25rem;
    }

    .nav ul li a {
      display: block;
      width: 100%;
      border-radius: 8px;
      font-size: 1rem;
      padding: 0.85rem 1rem;
      text-align: center;
    }

    :global(body.menu-open) {
      overflow: hidden;
    }
  }

  @media (max-width: 480px) {
    .profile {
      padding-right: 0;
    }
    
    .name {
      max-width: 46vw;
      font-size: 0.88rem;
    }

    .header img {
      height: 36px;
      width: 36px;
    }
  }
</style>

