---
import profileImg from '../images/layer.jpg';
import { profile } from '../data.js';
---

<section class="about-section" id="about">
  <div class="container">
    <div class="about-content">
      <div class="about-text">
        <p class="eyebrow">About</p>
        <h1>Backend systems and AI applications.</h1>
        <p class="intro">{profile.summary}</p>
        <p>
          I like building practical software that connects reliable APIs, automation,
          computer vision, and real-time user experiences into products that people can actually use.
        </p>

        <div class="tech-stack">
          <h2>Tech stack I'm familiar with</h2>
